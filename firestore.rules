rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ───────── Ajudantes ─────────
    function isSignedIn() { return request.auth != null; }

    // Super admin fixo (pelo e-mail) — funciona mesmo sem doc em /usuarios
    function emailAdmin() {
      return isSignedIn() && request.auth.token.email == 'jlrodrigues6900@gmail.com';
    }

    function tenhoDoc() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }
    function meuDoc() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    // Admin = super admin por e-mail OU campo isAdmin == true no /usuarios
    function isAdmin() {
      return emailAdmin() || (tenhoDoc() && meuDoc().isAdmin == true);
    }
    // Aprovado = admin OU status == 'aprovado'
    function isAprovado() {
      return isAdmin() || (tenhoDoc() && meuDoc().status == 'aprovado');
    }
    function isOwner(id) { return isSignedIn() && request.auth.uid == id; }

    // ───────── Usuários ─────────
    match /usuarios/{userId} {
      // cada um lê o próprio; admin lê todos
      allow read: if isOwner(userId) || isAdmin();
      // no cadastro, só cria o próprio doc, sempre pendente e sem ser admin
      allow create: if isOwner(userId)
        && request.resource.data.status == 'pendente'
        && request.resource.data.isAdmin == false;
      // aprovar/negar/promover é só o admin
      allow update, delete: if isAdmin();
    }

    // ───────── Log de consultas ─────────
    match /consultas_log/{doc} {
      allow create: if isAprovado();
      allow read: if isAprovado();
      allow update, delete: if isAdmin();
    }

    // ───────── Histórico de atividades ─────────
    match /atividades_log/{doc} {
      // create liberado a qualquer logado (registra "conta_criada" já no cadastro)
      allow create: if isSignedIn();
      allow read: if isAprovado();
      allow update, delete: if isAdmin();
    }

    // ───────── Presença (quem está online) ─────────
    match /presenca/{uid} {
      allow read: if isAdmin();
      allow create, update, delete: if isOwner(uid);
    }

    // ───────── Pré-cadastros (compartilhados) ─────────
    match /preCadastros/{doc} {
      allow read, create, update, delete: if isAprovado();
    }

    // ───────── Listas de prospecção salvas ─────────
    match /listasProspeccao/{doc} {
      // admin vê todas; usuário só as próprias
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isAprovado();
      // só o admin apaga/edita
      allow update, delete: if isAdmin();
    }

    // ───────── Prospecções (todas as buscas ficam guardadas) ─────────
    match /prospeccoes/{doc} {
      allow create: if isAprovado();
      allow read, update, delete: if isAdmin();
    }

    // ───────── Faturamento de postos (contas a pagar) ─────────
    // Cada usuário vê/gerencia SÓ as próprias faturas; admin vê todas.
    // (o app sempre consulta com where('uid','==', meu uid), então o read casa
    //  com a regra abaixo sem precisar de índice composto)
    match /faturas/{doc} {
      allow read:           if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create:         if isAprovado() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
    }

    // Qualquer outra coisa: negado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
