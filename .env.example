# Copie para .env e ajuste. Pra rodar local, os padrões já bastam.
PROJECT_NAME=cda
POSTGRES_PASSWORD=app

# Auth (Fase 3) — troque os dois em produção.
JWT_SECRET=dev-secret-troque-em-producao
SUPER_ADMIN_EMAIL=admin@arcom.com.br

# Consulta de CNPJ (Fase 4) — cole a chave real aqui (nunca no código).
ARCOM_API_BASE_URL=https://consultacnpj.arcom.com.br
ARCOM_API_KEY=

# Prospecção — geocode da fachada/Street View (Fase 5).
GEOAPIFY_API_KEY=

# Demais chaves de API externas entram aqui conforme cada fase as usa
# (ver docs/migracao/02-arquitetura-alvo.md e docs/migracao/09-fases.md).
# Nunca vão para o frontend — só o backend as lê.
